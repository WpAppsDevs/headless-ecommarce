# WordPress / WooCommerce site URL (no trailing slash)
# Changing this value switches the entire store — no other code changes needed.
NEXT_PUBLIC_WP_URL=https://your-wp-site.com

# Stripe publishable key
NEXT_PUBLIC_STRIPE_PK=pk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SITE_NAME=HeadlessECF
NEXT_PUBLIC_HERO_TITLE=Shop the Latest Collection
NEXT_PUBLIC_HERO_SUBTITLE=Discover premium products, delivered fast.
NEXT_PUBLIC_HERO_CTA_TEXT=Shop All Products
NEXT_PUBLIC_HERO_CTA_LINK=/products
